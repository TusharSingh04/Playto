# ── Core ──────────────────────────────────────────────────────────────────
# Generate a real key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database ──────────────────────────────────────────────────────────────
DB_NAME=playto_payouts
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ── Celery / Redis ────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Production-only (uncomment in prod, ignored in dev) ───────────────────
# CORS_ALLOWED_ORIGINS=https://app.example.com
# CSRF_TRUSTED_ORIGINS=https://app.example.com
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=2592000

# ── Throttles (per-minute caps) ───────────────────────────────────────────
# THROTTLE_USER=60/min
# THROTTLE_ANON=10/min
# THROTTLE_PAYOUT_CREATE=5/min

# ── Observability ─────────────────────────────────────────────────────────
# Sentry: leave blank to disable. If set, errors + perf are shipped on init.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=git-sha-or-tag
# SENTRY_TRACES_SAMPLE_RATE=0.05
LOG_LEVEL=INFO
