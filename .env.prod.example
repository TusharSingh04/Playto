# Production environment file. Copy to .env.prod and fill in real values
# before running:  docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
#
# DO NOT commit .env.prod. It is git-ignored.

# ── Django ────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Comma-separated. Must match the domain Caddy serves and any health-check URLs.
ALLOWED_HOSTS=payouts.example.com

# Frontend origin(s). With Caddy serving the SPA and the API on the same host
# this is just the public URL.
CORS_ALLOWED_ORIGINS=https://payouts.example.com
CSRF_TRUSTED_ORIGINS=https://payouts.example.com

# ── Database ──────────────────────────────────────────────────────────────
# These same values are used by both Django and the postgres container.
DB_NAME=playto_payouts
DB_USER=playto
DB_PASSWORD=

# ── Sentry (optional) ─────────────────────────────────────────────────────
# Leave blank to disable. When set, Django + Celery errors are shipped.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=git-sha-or-tag
